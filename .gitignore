# Ignore everything by default
*

# Allow directories so git can descend into them
!*/

# Always allow gitignore files themselves
!.gitignore

# Core workflow / build files
!Snakefile
!Makefile
!*.mk
!*.smk
!*.sh

# Code
!*.py
!*.R
!*.pl

# Config / metadata / env definitions
!*.yaml
!*.yml
!*.json
!*.csv
!*.tsv

# Documentation
!*.md
!*.txt

# Optional: allow lightweight notebooks only if you really want them tracked
#!*.ipynb

# Explicitly keep common repo directories traversable
!config/
!workflow/
!workflow/rules/
!envs/
!scripts/
!docs/

# Still ignore known heavy/generated things even if extensions would otherwise match
results/
logs/
benchmarks/
reports/
.snakemake/
tmp/
temp/
scratch/

# Ignore common bioinformatics heavy file types explicitly
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.fa
*.fa.gz
*.fasta
*.fasta.gz
*.fai
*.gfa
*.bam
*.bai
*.sam
*.cram
*.crai
*.vcf
*.vcf.gz
*.bcf
*.csi
*.bin
*.mmi
*.meryl


!resources/
!resources/external/
!resources/external/genomescope2.0/
!resources/external/genomescope2.0/genomescope.R
!resources/external/genomescope2.0/install.R
!resources/external/genomescope2.0/DESCRIPTION
!resources/external/genomescope2.0/NAMESPACE
!resources/external/genomescope2.0/R/
!resources/external/genomescope2.0/man/

!.github/
!.github/assets/
!.github/assets/rulegraph.svg
.ci/
.ci/

# Nextflow work directories
nextflow_work/
work/
.nextflow/
.nextflow.log*

# Nextflow work directories
nextflow_work/
work/
.nextflow/
.nextflow.log*
